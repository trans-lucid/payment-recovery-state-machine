{
  "name": "payment-recovery-state-machine-candidate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d",
    "logs": "docker compose logs -f",
    "migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/resetState.ts",
    "gateway:setup": "tsx scripts/setupGateway.ts",
    "queue:setup": "tsx scripts/setupQueue.ts",
    "seed": "npm run migrate && npm run db:reset && npm run gateway:setup && npm run queue:setup",
    "test": "vitest run tests/public",
    "test:unit": "vitest run tests/public/unit.test.ts",
    "test:integration": "vitest run tests/public/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "worker": "tsx src/reconciliationWorker.ts",
    "run": "tsx src/server.ts",
    "eval": "tsx src/settlementReport.ts",
    "clean": "docker compose down -v"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.821.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
