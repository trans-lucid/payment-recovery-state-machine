{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "candidate/src/**/*.ts",
    "candidate/scripts/**/*.ts",
    "candidate/tests/**/*.ts",
    "solution/src/**/*.ts",
    "solution/tests/**/*.ts",
    "evaluator/tests_hidden/**/*.ts"
  ]
}
